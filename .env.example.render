# === Paperclip Render Environment Variables ===
# Copy these to your Render service's Environment tab

# --- Required ---
HOST=0.0.0.0
PORT=3100
SERVE_UI=true

# Paperclip data paths (must be under persistent disk mount /data)
PAPERCLIP_HOME=/data/paperclip
PAPERCLIP_INSTANCE_ID=default

# Deployment mode: "authenticated" for cloud, "local_trusted" for dev
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public

# Auto-apply DB migrations on startup
PAPERCLIP_MIGRATION_AUTO_APPLY=true

# Heartbeat scheduler (enables agent wake cycles)
HEARTBEAT_SCHEDULER_ENABLED=true

# --- Claude CLI Session Persistence ---
# These paths must be on persistent disk to survive restarts
CLAUDE_CONFIG_DIR=/data/claude-config
HOME=/data/home
XDG_CONFIG_HOME=/data/home/.config

# --- Auth ---
# Set this to your Render service URL after first deploy
# PAPERCLIP_PUBLIC_URL=https://paperclip-XXXX.onrender.com
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=true  # Set after initial setup

# --- Secrets ---
# Copy from your local ~/.paperclip/instances/default/.env
PAPERCLIP_AGENT_JWT_SECRET=<copy-from-local>

# --- Optional: External Postgres (instead of embedded) ---
# DATABASE_URL=postgresql://user:pass@host:5432/paperclip

# --- Optional: S3 Storage (instead of local disk) ---
# PAPERCLIP_STORAGE_PROVIDER=s3
# PAPERCLIP_STORAGE_S3_BUCKET=your-bucket
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
